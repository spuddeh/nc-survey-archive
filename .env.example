# R2 credentials for scripts/gen-manifest.mjs and bulk uploads.
# Copy to .env and fill in. NEVER commit the real .env.
# Use an R2 API token (Cloudflare dashboard → R2 → Manage API Tokens) with
# Object Read (add Write if uploading via the S3 API / rclone / aws-cli).

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
R2_BUCKET=nc-survey
